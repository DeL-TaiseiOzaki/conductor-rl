# Conductor-RL secrets — copy to .env at the project root.
# The prime-rl sbatch template sources .env before launching.
# NEVER commit the actual .env file.

# Required: OpenRouter API key for worker calls during reward scoring.
# The conductor-workflow environment reads this via os.environ at rollout time.
OPENROUTER_API_KEY=

# Optional: Weights & Biases API key for experiment tracking.
WANDB_API_KEY=

# Optional: HuggingFace token (only needed for gated models; Qwen3.5-4B is non-gated).
# HUGGINGFACE_TOKEN=

# Optional: Override the judge model slug (default: nvidia/nemotron-3-ultra-550b-a55b:free).
# JUDGE_MODEL=
